{
  "name": "spring-guardian-ui",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node ./node_modules/@angular/cli/bin/ng.js serve --host 0.0.0.0 --port 4200 --proxy-config proxy.conf.json",
    "dev": "node ./node_modules/@angular/cli/bin/ng.js serve --host 0.0.0.0 --port 4200 --proxy-config proxy.conf.json",
    "build": "node ./node_modules/@angular/cli/bin/ng.js build",
    "watch": "node ./node_modules/@angular/cli/bin/ng.js build --watch --configuration development",
    "test": "node scripts/verify-ui-architecture.mjs",
    "test:build": "node ./node_modules/@angular/cli/bin/ng.js build"
  },
  "dependencies": {
    "@angular/animations": "18.2.13",
    "@angular/common": "18.2.13",
    "@angular/compiler": "18.2.13",
    "@angular/core": "18.2.13",
    "@angular/forms": "18.2.13",
    "@angular/platform-browser": "18.2.13",
    "@angular/platform-browser-dynamic": "18.2.13",
    "@angular/router": "18.2.13",
    "rxjs": "~7.8.1",
    "tslib": "^2.6.2",
    "zone.js": "~0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "18.2.13",
    "@angular/cli": "18.2.13",
    "@angular/compiler-cli": "18.2.13",
    "typescript": "~5.5.4"
  }
}
